# Spotify app credentials (https://developer.spotify.com/dashboard)
# Reading playlist tracks requires a user-authorized (Authorization Code) token, not
# just Client Credentials — run "npm run spotify-login" once to obtain it. That saves
# a refresh token to DATA_DIR/spotify_refresh_token.txt, not here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# The playlist to poll. Grab the ID from the share link: open.spotify.com/playlist/<PLAYLIST_ID>
SPOTIFY_PLAYLIST_ID=

# Telegram API credentials for the userbot (https://my.telegram.org -> API development tools)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram username (no @) of the Deezload bot to forward links to
DEEZLOAD_USERNAME=deezload2bot

# How often to poll the playlist, in milliseconds
POLL_INTERVAL_MS=12000

# Port for the local status/health endpoint
PORT=8787

# Where session.txt and state.json are persisted (mount this as a volume in Docker)
DATA_DIR=./data
